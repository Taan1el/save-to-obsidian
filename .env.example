OBSIDIAN_VAULT_PATH=C:\Users\YOUR_NAME\Documents\Obsidian Vault
OBSIDIAN_CHATGPT_FOLDER=AI Chats\ChatGPT\Saved
HELPER_TOKEN=change-this-to-a-long-random-local-secret
HELPER_PORT=8766
HELPER_DEV=0
MAX_REQUEST_BYTES=1000000
ALLOWED_EXTENSION_ORIGIN=

# AI_PROVIDER options:
# ollama, openai, anthropic, gemini, openai-compatible
AI_PROVIDER=ollama

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Use for OpenRouter, LM Studio, llama.cpp servers, Groq-compatible gateways,
# or any service exposing an OpenAI-style /v1/chat/completions endpoint.
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
